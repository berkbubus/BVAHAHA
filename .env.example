# Copy this file to `.env` and fill in your keys.

# OpenAI API key — used by the evaluation stage
#   evaluation/category_persona.py  (persona generation, gpt-4.1)
#   evaluation/joke_scoring.py      (LLM-as-a-Judge, gpt-4o)
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API key — used by the generation stage
#   generation/lets_run.py          (google/gemini-3-flash-preview)
OPENROUTER_API_KEY=your_openrouter_api_key_here
